# MySQL — copie para o .env e ajuste.
#
# --- IMPORTANTE: não defina DATABASE_URL e MYSQL_* ao mesmo tempo no painel da hospedagem.
# Se MYSQL_HOST/USER/DATABASE estiverem incompletos, a app usa DATABASE_URL e pode ligar como root@127.0.0.1.
# Com MYSQL_* completos, apague DATABASE_URL ou deixe-a vazia.
#
# Opção A — variáveis separadas (recomendado; senha com # : ? & @ não precisa codificar):
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=cole_a_senha
# MYSQL_DATABASE=sol_do_recreio
#
# Hostinger: use o utilizador tipo u123456_nome (não root), MYSQL_HOST conforme o painel (geralmente localhost no mesmo servidor).
#
# Erro root@127.0.0.1: remova DATABASE_URL; use MYSQL_HOST=localhost; reinicie Node.
# Erro com ::1: MYSQL_MAP_LOCALHOST_TO_IPV4=1
#
# Opção B — só URL (não defina MYSQL_HOST / MYSQL_USER / MYSQL_DATABASE no painel, ou esta opção é ignorada):
# DATABASE_URL=mysql://root:senha@localhost:3306/sol_do_recreio
#
# Os scripts npm run db:init, db:ping, db:seed-admin aceitam DATABASE_URL ou MYSQL_*.
#
# Local (MySQL na sua máquina):
# DATABASE_URL="mysql://root@localhost:3306/sol_do_recreio"
#
# Hostinger (app no MESMO plano da hospedagem):
# DATABASE_URL="mysql://USUARIO:SENHA@localhost:3306/uXXXXXX_nome_do_banco"
#
# Hostinger (app no seu PC ou Vercel): ative Remote MySQL no hPanel e use o hostname exibido lá:
# DATABASE_URL="mysql://USUARIO:SENHA@hostname-do-painel.hostinger:3306/uXXXXXX_nome_do_banco"
#
# MySQL remoto com TLS (só se o painel indicar SSL): DATABASE_SSL=1
# ou acrescente ao URL: ?ssl=true  (ex.: .../uXXXX_nome?ssl=true)
#
# Vercel (ou outro deploy): painel → Settings → Environment Variables → DATABASE_URL
#
# Senha com caracteres especiais (@ # : / ? & etc.) — codifique na URL (ex.: @ → %40):
#   senha real: Blade1411@20  →  na URL: Blade1411%4020
#   DATABASE_URL="mysql://USER:Blade1411%4020@localhost:3306/nome_do_banco"
# O servidor também tenta corrigir automaticamente senhas com "@" quando o URL tem vários @.

DATABASE_URL="mysql://usuario:senha@localhost:3306/sol_do_recreio"

# PWA (service worker). Só ligue em produção se precisar de offline: define na build (NEXT_PUBLIC_*).
# NEXT_PUBLIC_ENABLE_PWA=true



# Segredo para assinar JWT (gere uma string longa aleatória em produção)

AUTH_SECRET="troque-por-uma-chave-secreta-longa-em-producao"

# URL pública do site (links em e-mail de recuperação de senha). Ex.: https://seudominio.com.br
# NEXT_PUBLIC_SITE_URL="https://seudominio.com.br"

# E-mail transacional — opção 1: Resend (https://resend.com)
# RESEND_API_KEY="re_..."
# E-mail remetente verificado no Resend:
# EMAIL_FROM="Sol do Recreio <noreply@seudominio.com.br>"

# E-mail transacional — opção 2: SMTP (Nodemailer)
# SMTP_HOST="smtp.seuprovedor.com"
# SMTP_PORT="587"
# SMTP_USER="usuario"
# SMTP_PASSWORD="senha"
# EMAIL_FROM="Sol do Recreio <noreply@seudominio.com.br>"



# Conta de administrador criada/atualizada pelo script: npm.cmd run db:seed-admin

# Troque a senha em produção.

ADMIN_EMAIL="admin@gmail.com"

ADMIN_PASSWORD="9944"

ADMIN_NAME="Administrador"


# Firebase Admin — UMA das três (Console → Contas de serviço → Gerar chave privada):
# FIREBASE_SERVICE_ACCOUNT_JSON="..."  (uma linha; npm run firebase:service-account-line -- "C:\chave.json")
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# GOOGLE_APPLICATION_CREDENTIALS=C:/caminho/absoluto/serviceAccountKey.json
#
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json



NEXT_PUBLIC_FIREBASE_API_KEY=""

NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="seu-projeto.firebaseapp.com"

NEXT_PUBLIC_FIREBASE_PROJECT_ID=""

NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="seu-projeto.appspot.com"

NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""

NEXT_PUBLIC_FIREBASE_APP_ID=""

# Opcional (Analytics no Console)

NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""


