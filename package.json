{
  "name": "sol-do-recreio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev:fresh": "npm run dev:clean && npm run dev",
    "check": "npm run lint && npm run build",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint",
    "android:add": "npx cap add android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "db:init": "node scripts/init-db.mjs",
    "db:seed-admin": "node scripts/seed-admin.mjs",
    "db:setup": "node scripts/init-db.mjs && node scripts/seed-admin.mjs",
    "db:ping": "node scripts/test-mysql.mjs",
    "db:migrate-cashback": "node scripts/migrate-cashback.mjs",
    "db:migrate-admin-features": "node scripts/migrate-admin-features.mjs",
    "firebase:service-account-line": "node scripts/service-account-to-env.mjs",
    "qr:entrar-png": "node scripts/generate-qr-entrar-png.mjs",
    "deploy:firebase": "firebase deploy --only hosting",
    "firebase:enable-webframeworks": "firebase experiments:enable webframeworks"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "bcryptjs": "^3.0.2",
    "jose": "^6.0.10",
    "mysql2": "^3.14.0",
    "next": "15.5.4",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.7",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "firebase-tools": "^14.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
