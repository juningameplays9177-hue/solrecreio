# MySQL — copie para o .env e ajuste.
#
# Local (MySQL na sua máquina):
# DATABASE_URL="mysql://root@localhost:3306/sol_do_recreio"
#
# Hostinger (app no MESMO plano da hospedagem):
# DATABASE_URL="mysql://USUARIO:SENHA@localhost:3306/uXXXXXX_nome_do_banco"
#
# Hostinger (app no seu PC ou Vercel): ative Remote MySQL no hPanel e use o hostname exibido lá:
# DATABASE_URL="mysql://USUARIO:SENHA@hostname-do-painel.hostinger:3306/uXXXXXX_nome_do_banco"

DATABASE_URL="mysql://usuario:senha@localhost:3306/sol_do_recreio"



# Segredo para assinar JWT (gere uma string longa aleatória em produção)

AUTH_SECRET="troque-por-uma-chave-secreta-longa-em-producao"



# Conta de administrador criada/atualizada pelo script: npm.cmd run db:seed-admin

# Troque a senha em produção.

ADMIN_EMAIL="admin@gmail.com"

ADMIN_PASSWORD="9944"

ADMIN_NAME="Administrador"


# Firebase — login com Google (Console: projeto > Authentication > Google; Project settings > Web app)

# Opção A — JSON em uma linha (veja: npm run firebase:service-account-line -- "C:\chave.json")
# Opção B — caminho para o arquivo baixado (como require("path/to/serviceAccountKey.json"))
# Opção C — variável padrão Google Cloud, só o caminho do .json:
# FIREBASE_SERVICE_ACCOUNT_JSON="{\"type\":\"service_account\",...}"
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# GOOGLE_APPLICATION_CREDENTIALS=C:\\caminho\\serviceAccountKey.json



NEXT_PUBLIC_FIREBASE_API_KEY=""

NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="seu-projeto.firebaseapp.com"

NEXT_PUBLIC_FIREBASE_PROJECT_ID=""

NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="seu-projeto.appspot.com"

NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""

NEXT_PUBLIC_FIREBASE_APP_ID=""

# Opcional (Analytics no Console)

NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""


