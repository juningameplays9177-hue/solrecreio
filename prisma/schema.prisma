generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CLIENT
}

enum PurchaseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CashbackRedemptionStatus {
  PENDING
  APPROVED
  REJECTED
  USED
  CANCELLED
}

enum CashbackLedgerKind {
  EARN
  USE
}

model User {
  id               Int      @id @default(autoincrement()) @db.UnsignedInt
  email            String   @unique @db.VarChar(255)
  passwordHash     String   @map("password_hash") @db.VarChar(255)
  name             String   @db.VarChar(255)
  cpf              String?  @unique @db.VarChar(11)
  phone            String?  @db.VarChar(32)
  role             UserRole
  cashbackBalance  Decimal  @default(0) @map("cashback_balance") @db.Decimal(10, 2)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  purchases            Purchase[]
  cashbackRedemptions  CashbackRedemption[]
  notifications        Notification[]
  passwordResetTokens  PasswordResetToken[]
  cashbackLedger       CashbackLedger[]

  @@map("sr_User")
}

model Purchase {
  id               Int            @id @default(autoincrement()) @db.UnsignedInt
  userId           Int            @map("user_id") @db.UnsignedInt
  amount           Decimal        @db.Decimal(10, 2)
  creditedAmount   Decimal?       @map("credited_amount") @db.Decimal(10, 2)
  status           PurchaseStatus @default(PENDING)
  filePath         String?        @map("file_path") @db.VarChar(512)
  originalFilename String?        @map("original_filename") @db.VarChar(255)
  adminNote        String?        @map("admin_note") @db.Text
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamp(0)
  reviewedAt       DateTime?      @map("reviewed_at") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status], map: "idx_sr_purchase_status")
  @@index([userId], map: "idx_sr_purchase_user")
  @@map("sr_Purchase")
}

model CashbackRedemption {
  id          Int                      @id @default(autoincrement()) @db.UnsignedInt
  userId      Int                      @map("user_id") @db.UnsignedInt
  amount      Decimal                  @db.Decimal(10, 2)
  status      CashbackRedemptionStatus @default(PENDING)
  couponCode  String?                  @unique @map("coupon_code") @db.VarChar(64)
  adminNote   String?                  @map("admin_note") @db.Text
  createdAt   DateTime                 @default(now()) @map("created_at") @db.Timestamp(0)
  reviewedAt  DateTime?                @map("reviewed_at") @db.Timestamp(0)
  approvedAt  DateTime?                @map("approved_at") @db.Timestamp(0)
  rejectedAt  DateTime?                @map("rejected_at") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_sr_cashback_redemption_user")
  @@index([status], map: "idx_sr_cashback_redemption_status")
  @@index([createdAt], map: "idx_sr_cashback_redemption_created")
  @@map("sr_CashbackRedemption")
}

model AppSetting {
  key   String @id @map("key") @db.VarChar(64)
  value String @db.Text

  @@map("sr_AppSetting")
}

model Notification {
  id        Int       @id @default(autoincrement()) @db.UnsignedInt
  userId    Int       @map("user_id") @db.UnsignedInt
  title     String    @db.VarChar(255)
  body      String?   @db.Text
  readAt    DateTime? @map("read_at") @db.Timestamp(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_sr_notification_user")
  @@index([userId, readAt], map: "idx_sr_notification_unread")
  @@map("sr_Notification")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement()) @db.UnsignedInt
  userId    Int       @map("user_id") @db.UnsignedInt
  tokenHash String    @map("token_hash") @db.Char(64)
  expiresAt DateTime  @map("expires_at") @db.DateTime(0)
  usedAt    DateTime? @map("used_at") @db.DateTime(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash], map: "idx_sr_pwd_reset_token_hash")
  @@index([userId], map: "idx_sr_pwd_reset_user")
  @@index([expiresAt], map: "idx_sr_pwd_reset_expires")
  @@map("sr_PasswordResetToken")
}

model CashbackLedger {
  id           BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  userId       Int                @map("user_id") @db.UnsignedInt
  kind         CashbackLedgerKind
  amount       Decimal            @db.Decimal(10, 2)
  balanceAfter Decimal            @map("balance_after") @db.Decimal(10, 2)
  source       String             @db.VarChar(48)
  refType      String?            @map("ref_type") @db.VarChar(32)
  refId        Int?               @map("ref_id") @db.UnsignedInt
  metadata     Json?
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamp(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], map: "idx_sr_cashback_ledger_user_created")
  @@map("sr_CashbackLedger")
}
